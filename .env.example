NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=SUA_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=SUA_SERVICE_ROLE_KEY

# Email (Resend) — opcional. Sem estas variáveis os emails são silenciosamente ignorados.
RESEND_API_KEY=
NOTIFY_FROM_EMAIL=no-reply@seudominio.com.br
ADMIN_EMAIL=admin@seudominio.com.br

# Notion (sincronização automática de chamados de feedback) — opcional. Sem
# estas variáveis a sincronização é silenciosamente ignorada. Requer uma
# Internal Integration criada em notion.so/my-integrations, compartilhada com
# a base "Chamados" (Conectores da página no Notion).
NOTION_API_KEY=
NOTION_CHAMADOS_DATA_SOURCE_ID=cae77ba3-60af-4e67-ae31-e81cb7c2f362
